{
  "cli": {
    "version": ">= 3.15.0",
    "appVersionSource": "local"
  },
  "build": {
    "base": {
      "node": "20.15.0",
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=8192"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": false,
      "channel": "development",
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "env": {
          "JS_RUNTIME": "hermes"
        }
      }
    },
    "Development": {
      "extends": "development"
    },
    "preview": {
      "extends": "base",
      "channel": "preview",
      "android": {
        "buildType": "apk",
        "env": {
          "JS_RUNTIME": "hermes"
        }
      },
      "distribution": "internal"
    },
    "production": {
      "extends": "base",
      "channel": "production",
      "android": {
        "buildType": "apk",
        "env": {
          "JS_RUNTIME": "hermes"
        }
      },
      "env": {
        "envFile": ".env"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
