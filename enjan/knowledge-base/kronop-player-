### 3.4 Render Layer - Zero-copy + NPU Super Resolution

```cpp
// kronop_render.cpp - Vulkan Zero-copy + NPU Upscaling
#include <vulkan/vulkan.h>
#include <android/hardware_buffer.h>

class KronopRenderer {
private:
    VkDevice vk_device_;
    VkQueue vk_queue_;
    
    // NPU for super resolution (Red Note style)
    struct NPUContext {
        void* snpe_context;      // Qualcomm SNPE
        void* nnapi_model;       // Android NNAPI
        bool is_available;
    } npu_;
    
public:
    KronopRenderer() {
        initVulkan();
        initNPU();
    }
    
    void initVulkan() {
        // Create Vulkan device with zero-copy extensions
        VkInstanceCreateInfo inst_info = {};
        inst_info.sType = VK_STRUCTURE_TYPE_INSTANCE_CREATE_INFO;
        
        // Enable dma-buf extension for zero-copy
        const char* extensions[] = {
            VK_KHR_EXTERNAL_MEMORY_FD_EXTENSION_NAME,
            VK_KHR_EXTERNAL_SEMAPHORE_FD_EXTENSION_NAME
        };
        
        vkCreateInstance(&inst_info, nullptr, &vk_instance_);
    }
    
    void render(DecodedFrame* frame) {
        // Step 1: Check if NPU upscaling needed
        if (frame->width < 1080 && npu_.is_available && shouldUpscale()) {
            frame = npuUpscale(frame);
        }
        
        // Step 2: Zero-copy import to Vulkan
        VkImportMemoryFdInfoKHR import_info = {};
        import_info.sType = VK_STRUCTURE_TYPE_IMPORT_MEMORY_FD_INFO_KHR;
        import_info.handleType = VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
        import_info.fd = frame->dma_buf_fd;  // Direct GPU access
        
        VkMemoryAllocateInfo alloc_info = {};
        alloc_info.sType = VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO;
        alloc_info.pNext = &import_info;
        alloc_info.allocationSize = frame->size;
        
        VkDeviceMemory memory;
        vkAllocateMemory(vk_device_, &alloc_info, nullptr, &memory);
        
        // Step 3: Create image from memory
        VkImage image;
        VkImageCreateInfo image_info = {};
        image_info.sType = VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO;
        image_info.imageType = VK_IMAGE_TYPE_2D;
        image_info.format = VK_FORMAT_R8G8B8A8_UNORM;
        image_info.extent = {frame->width, frame->height, 1};
        
        vkCreateImage(vk_device_, &image_info, nullptr, &image);
        vkBindImageMemory(vk_device_, image, memory, 0);
        
        // Step 4: Direct render to screen
        vkQueueSubmit(vk_queue_, 1, &submit_info, VK_NULL_HANDLE);
        
        // Total time: < 8ms (60fps)
    }
    
    DecodedFrame* npuUpscale(DecodedFrame* input) {
        // NPU super resolution (Red Note's 360p -> 1080p)
        if (input->width == 640 && input->height == 360) {
            // Prepare NPU input tensor
            NPUTensor input_tensor = {
                .data = input->data,
                .width = 640,
                .height = 360,
                .format = NPU_FORMAT_RGB
            };
            
            // Run NPU inference
            NPUTensor output_tensor = npu_.inference(&input_tensor);
            
            return new DecodedFrame(
                output_tensor.data,
                1920, 1080,  // Upscaled to 1080p
                input->pts
            );
        }
        
        return input;
    }
    
    bool shouldUpscale() {
        // Only upscale if battery > 30% and not overheating
        int battery = getBatteryLevel();
        int temp = getDeviceTemp();
        
        return battery > 30 && temp < 45;
    }
};
