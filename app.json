{
  "expo": {
    "main": "expo-router/entry",
    "name": "Kronop",
    "slug": "kronop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "com.kronop.app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to personalize content and services.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app uses your location to personalize content and services."
      }
    },
    "android": {
      "package": "com.anonymous.kronop",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": true,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "splash": {
            "image": "./assets/images/logo.png",
            "imageWidth": 200,
            "resizeMode": "contain",
            "backgroundColor": "#000000"
          },
          "backgroundColor": "#000000"
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "@react-native-google-signin/google-signin",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": ""
        }
      ],
      "expo-asset",
      "expo-audio",
      "expo-font",
      "expo-localization",
      "expo-mail-composer",
      "expo-secure-store",
      "expo-sqlite",
      "expo-video",
      [
        "expo-build-properties",
        {}
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b119a84a-5a57-4eb1-9a69-e50bb1cfd408"
      },
      "EXPO_PUBLIC_PORT": "",
      "EXPO_PUBLIC_RENDER_SERVICE_ID": "",
      "EXPO_PUBLIC_BASE_URL": "",
      "EXPO_PUBLIC_ENVIRONMENT": "",
      "EXPO_PUBLIC_DEPLOYMENT_PORT": "",
      "EXPO_PUBLIC_REPLACEMENT_DONE": "",
      "EXPO_PUBLIC_MONGODB_URI": "",
      "EXPO_PUBLIC_SUPABASE_URL": "",
      "EXPO_PUBLIC_SUPABASE_ANON_KEY": "",
      "EXPO_PUBLIC_SUPABASE_DB_URL": "",
      "EXPO_PUBLIC_SUPABASE_PROJECT_ID": "",
      "EXPO_PUBLIC_SUPABASE_SERVICE_ROLE_KEY": "",
      "EXPO_PUBLIC_R2_ACCOUNT_ID": "",
      "EXPO_PUBLIC_R2_ACCESS_KEY_ID": "",
      "EXPO_PUBLIC_R2_SECRET_ACCESS_KEY": "",
      "EXPO_PUBLIC_R2_ENDPOINT": "",
      "EXPO_PUBLIC_BUCKET_REELS": "",
      "EXPO_PUBLIC_BUCKET_VIDEO": "",
      "EXPO_PUBLIC_BUCKET_LIVE": "",
      "EXPO_PUBLIC_BUCKET_STORY": "",
      "EXPO_PUBLIC_BUCKET_PHOTO": "",
      "EXPO_PUBLIC_BUCKET_SONG": "",
      "EXPO_PUBLIC_FIREBASE_API_KEY": "",
      "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "",
      "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "",
      "EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET": "",
      "EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "",
      "EXPO_PUBLIC_FIREBASE_APP_ID": "",
      "EXPO_PUBLIC_ESTAELIT_BNA_KAR_DO": ""
    }
  }
}
